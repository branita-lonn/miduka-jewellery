// prisma/schema.prisma
// Core database schema for MiDuka — single-seller e-commerce platform

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  STORE_OWNER
  CUSTOMER
}

enum FontChoice {
  INTER
  POPPINS
  LATO
  NUNITO
}

enum OrderStatus {
  PLACED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MPESA
  STRIPE
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum EngagementType {
  VIEW
  ADD_TO_CART
  PURCHASE
}

enum BundleType {
  BUY_X_GET_Y_FREE
  BUY_X_GET_PERCENT_OFF
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
}

// ─── AUTH MODELS ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  cart         Cart?
  orders       Order[]
  addresses    Address[]
  wishlist     Wishlist?
  stockAlerts  StockAlert[]
  reviews      Review[]
  reviewVotes  ReviewVote[]
  engagements  Engagement[]
  loyaltyAccount LoyaltyAccount?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── STORE SETTINGS ───────────────────────────────────────────────────────────

model StoreSettings {
  id              String     @id @default(cuid())
  storeName       String     @default("MiDuka")
  storeTagline    String?
  logoUrl         String?
  logoBlurDataUrl String?
  faviconUrl      String?
  accentColor     String     @default("#3B82F6")
  fontChoice      FontChoice @default(INTER)
  socialLinks     Json?
  returnPolicy    String?    @db.Text
  aboutPage       String?    @db.Text
  privacyPolicy   String?    @db.Text
  contactPage     String?    @db.Text
  whatsappNumber  String?
  contactEmail    String?
  contactPhone    String?
  businessHours   Json?
  enableStripe    Boolean    @default(true)
  enableMpesa     Boolean    @default(true)
  whatsappOrderNotifications Boolean @default(false)
  whatsappNotificationNumber String?
  metaTitle       String?
  metaDescription String?
  heroHeadline    String?
  heroSubheadline String?
  heroImageUrl    String?
  heroBlurDataUrl String?
  heroCtaText     String?
  heroCtaLink     String?
  
  // Global carousel auto-advance interval in milliseconds (default 5s)
  heroCarouselInterval  Int     @default(5000)
  // Whether the carousel auto-plays or requires manual interaction
  heroCarouselAutoplay  Boolean @default(true)
  
  // Loyalty & Marketing
  loyaltyPointsPerKes    Int      @default(1)
  loyaltyRedemptionRate Int      @default(100)
  whatsappEnabled       Boolean  @default(false)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?  @db.Text
  price          Decimal
  compareAtPrice Decimal?
  tags           String[]
  isActive       Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  isOnSale       Boolean  @default(false)
  stockQuantity  Int      @default(0)
  lowStockThreshold Int   @default(5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  categoryId     String?

  category      Category?        @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  stockAlerts   StockAlert[]
  reviews       Review[]
  engagements   Engagement[]
  flashSale     FlashSale?
}

model Category {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  imageUrl        String?
  imageBlurDataUrl String?
  parentId        String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]
}

model ProductImage {
  id          String   @id @default(cuid())
  url         String
  altText     String?
  colour      String?
  blurDataUrl String?
  sortOrder   Int      @default(0)
  productId   String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  colour        String?
  size          String?
  material      String?
  priceOverride Decimal?
  stockQuantity Int      @default(0)
  lowStockThreshold Int   @default(5)
  sku           String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  stockAlerts StockAlert[]
}

// ─── CART ─────────────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String?  @unique
  sessionId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    CartItem[]
  abandonedCart AbandonedCartRecord?

  @@index([sessionId])
}

model AbandonedCartRecord {
  id             String    @id @default(cuid())
  cartId         String    @unique
  customerId     String
  reminderSentAt DateTime?
  convertedAt    DateTime?
  createdAt      DateTime  @default(now())

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
}

// ─── ORDERS ───────────────────────────────────────────────────────────────────

model Order {
  id                     String        @id @default(cuid())
  orderNumber            String        @unique
  status                 OrderStatus   @default(PLACED)
  customerId             String?
  guestEmail             String?
  guestName              String?
  guestPhone             String?
  shippingAddressId      String
  subtotal               Decimal
  discountAmount         Decimal       @default(0)
  shippingCost           Decimal       @default(0)
  taxAmount              Decimal       @default(0)
  total                  Decimal
  couponCode             String?
  couponId               String?
  paymentMethod          PaymentMethod
  paymentStatus          PaymentStatus @default(PENDING)
  mpesaReceiptNumber     String?
  mpesaCheckoutRequestId String?
  stripePaymentIntentId  String?
  notes                  String?
  
  // Promotional Fields
  giftCardCode           String?
  giftCardDiscount       Decimal       @default(0)
  loyaltyPointsRedeemed Int           @default(0)
  loyaltyPointsEarned   Int           @default(0)

  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  customer        User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  shippingAddress Address     @relation(fields: [shippingAddressId], references: [id])
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  reviews         Review[]

  @@index([status])
  @@index([customerId])
  @@index([paymentStatus])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  productName  String
  variantLabel String?
  quantity     Int
  unitPrice    Decimal
  total        Decimal
  createdAt    DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model Address {
  id           String   @id @default(cuid())
  customerId   String?
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  county       String
  postalCode   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer User?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orders   Order[]

  @@index([customerId])
}

// ─── COUPONS ──────────────────────────────────────────────────────────────────

model Coupon {
  id                 String     @id @default(cuid())
  code               String     @unique
  type               CouponType
  value              Decimal
  minimumOrderAmount Decimal?
  maxUses            Int?
  maxUsesPerCustomer Int?
  usedCount          Int        @default(0)
  isActive           Boolean    @default(true)
  expiresAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  orders Order[]
}

// ─── DELIVERY ZONES ───────────────────────────────────────────────────────────

model DeliveryZone {
  id                    String   @id @default(cuid())
  name                  String
  counties              String[]
  shippingCost          Decimal
  freeShippingThreshold Decimal?
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── CUSTOMER FEATURES ────────────────────────────────────────────────────────

model Wishlist {
  id         String   @id @default(cuid())
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
}

model StockAlert {
  id         String   @id @default(cuid())
  email      String
  customerId String?
  productId  String
  variantId  String?
  isNotified Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer User?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId, isNotified])
  @@index([email])
}

// ─── REVIEWS ──────────────────────────────────────────────────────────────────

model Review {
  id                 String   @id @default(cuid())
  rating             Int
  title              String?
  body               String   @db.Text
  photos             String[]
  isVerifiedPurchase Boolean  @default(false)
  productId          String
  customerId         String
  orderId            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product  Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  votes    ReviewVote[]
  reply    ReviewReply?

  @@unique([productId, customerId])
  @@index([productId])
  @@index([customerId])
}

model ReviewVote {
  id         String   @id @default(cuid())
  reviewId   String
  customerId String
  isHelpful  Boolean
  createdAt  DateTime @default(now())

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  customer User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([reviewId, customerId])
  @@index([reviewId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// ─── ANALYTICS ────────────────────────────────────────────────────────────────

model Engagement {
  id         String         @id @default(cuid())
  type       EngagementType
  productId  String
  sessionId  String?
  customerId String?
  createdAt  DateTime       @default(now())

  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer User?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([productId, type])
  @@index([createdAt])
}

model DashboardNotification {
  id        String   @id @default(cuid())
  type      String   // NEW_ORDER, LOW_STOCK, NEW_REVIEW
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// ─── PROMOTIONS & MARKETING ───────────────────────────────────────────────────

model FlashSale {
  id        String   @id @default(cuid())
  productId String   @unique
  salePrice Decimal
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([endTime])
}

model Bundle {
  id              String     @id @default(cuid())
  name            String
  description     String?    @db.Text
  type            BundleType
  buyQuantity     Int
  getQuantity     Int?       // For BUY_X_GET_Y_FREE
  discountPercent Int?       // For BUY_X_GET_PERCENT_OFF
  isActive        Boolean    @default(true)
  productIds      String[]   // IDs of products this bundle applies to
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model LoyaltyAccount {
  id             String   @id @default(cuid())
  customerId     String   @unique
  points         Int      @default(0)
  lifetimePoints Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     User                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id               String                 @id @default(cuid())
  loyaltyAccountId String
  type             LoyaltyTransactionType
  points           Int
  orderId          String?
  description      String
  createdAt        DateTime               @default(now())

  loyaltyAccount LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  @@index([loyaltyAccountId])
}

model GiftCard {
  id                    String    @id @default(cuid())
  code                  String    @unique
  initialValue          Decimal
  remainingValue        Decimal
  currency              String    @default("KES")
  expiresAt             DateTime?
  purchasedByCustomerId String?
  redeemedByCustomerId  String?
  recipientEmail        String?
  recipientName         String?
  senderName            String?
  orderId               String?
  isActive              Boolean   @default(true)
  paymentStatus         PaymentStatus @default(PENDING)
  paymentMethod         PaymentMethod?
  mpesaCheckoutRequestId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([code])
  @@index([mpesaCheckoutRequestId])
}

// ─── STATIC PAGES ─────────────────────────────────────────────────────────────

model StaticPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id               String   @id @default(cuid())

  // Content
  headline         String?
  subheadline      String?
  ctaText          String?
  ctaLink          String?

  // Images — two per slide for responsive display
  desktopImageUrl  String          // Required — shown on md+ screens (≥768px)
  mobileImageUrl   String          // Required — shown on <md screens

  // Cloudinary public IDs for future deletion support
  desktopPublicId  String?
  mobilePublicId   String?

  // Control
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)

  // Optional: overlay tint for text legibility over bright images
  // Stored as a CSS rgba string, e.g. "rgba(0,0,0,0.45)"
  overlayColor     String?  @default("rgba(0,0,0,0.35)")

  // Optional: text alignment on this slide ("left" | "center" | "right")
  textAlign        String?  @default("left")

  // Optional: auto-advance duration override per slide (milliseconds)
  // Null = use the global StoreSettings default
  duration         Int?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@map("hero_slides")
}
